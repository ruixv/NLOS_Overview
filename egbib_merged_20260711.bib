@article{yeCompressedSensingActive2021,
  abstract = {Non-line-of-sight (NLOS) imaging techniques have the ability to look around corners, which is of growing interest for diverse applications. We explore compressed sensing in active NLOS imaging and show that compressed sensing can greatly reduce the required number of scanning points without the compromise of the imaging quality. Particularly, we perform the analysis for both confocal NLOS imaging and active occlusion-based periscopy. In experiment, we demonstrate confocal NLOS imaging with only 5 \texttimes{} 5 scanning points for reconstructing a three-dimensional hidden image which has 64 \texttimes{} 64 spatial resolution. The results show that compressed sensing can reduce the scanning points and the total capture time, while keeping the imaging quality. This will be desirable for high speed NLOS applications.},
