  issn = {2472-7636},
  keywords = {Cameras,computational photography,Delays,Detectors,Focusing,focusing lens,image reconstruction,Image reconstruction,imaging around the corners,lenses,nonline-of-sight imaging technique,nonline-of-sight scanning,object detection,optical focusing,pulsed sources,quadratic delay profile,quadratic delays,quadratic phase,reconstruction algorithm,single gated detector,SNLOS,temporal focusing,time-of-flight cameras,Transient analysis,virtual detector locations,virtual detectors,virtual source},
  month = {May},
