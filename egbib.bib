@article{seideltwodimensionalnonlineofsightscene2021,
    title = {Two-{Dimensional} {Non}-{Line}-of-{Sight} {Scene} {Estimation} {From} a {Single} {Edge} {Occluder}},
    volume = {7},
    //issn = {2333-9403},
    //doi = {10.1109/TCI.2020.3037405},
    abstract = {Passive non-line-of-sight imaging methods are often faster and stealthier than their active counterparts, requiring less complex and costly equipment. However, many of these methods exploit motion of an occluder or the hidden scene, or require knowledge or calibration of complicated occluders. The edge of a wall is a known and ubiquitous occluding structure that may be used as an aperture to image the region hidden behind it. Light from around the corner is cast onto the floor forming a fan-like penumbra rather than a sharp shadow. Subtle variations in the penumbra contain a remarkable amount of information about the hidden scene. Previous work has leveraged the vertical nature of the edge to demonstrate 1D (in angle measured around the corner) reconstructions of moving and stationary hidden scenery from as little as a single photograph of the penumbra. In this work, we introduce a second reconstruction dimension: range measured from the edge. We derive a new forward model, accounting for radial falloff, and propose two inversion algorithms to form 2D reconstructions from a single photograph of the penumbra. Performances of both algorithms are demonstrated on experimental data corresponding to several different hidden scene configurations. A Cramér-Rao bound analysis further demonstrates the feasibility (and utility) of the 2D corner camera.},
    journal = {IEEE Transactions on Computational Imaging},
    author = {Seidel, Sheila W. and Murray-Bruce, John and Ma, Yanting and Yu, Christopher and Freeman, William T. and Goyal, Vivek K},
    year = {2021},
    //note = {Conference Name: IEEE Transactions on Computational Imaging},
    keywords = {Cameras, Computational photography, computer vision, corner camera, Estimation, Image edge detection, Image reconstruction, Imaging, non-line-of-sight imaging, remote sensing, Three-dimensional displays, Two dimensional displays},
    //pages = {58--72},
}
